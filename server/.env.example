# PayHero API base URL (example)
PAYHERO_API_URL=https://backend.payhero.co.ke/api/v2
PAYHERO_API_KEY=your_payhero_api_key_here
PAYHERO_CHANNEL_ID=123
PAYHERO_PROVIDER=m-pesa

# Public base url where this server is reachable (used to build callback URL)
CALLBACK_BASE_URL=https://your-public-domain.example

# Firebase service account JSON path OR JSON as single-line string
# Provide either FIREBASE_SERVICE_ACCOUNT_PATH or FIREBASE_SERVICE_ACCOUNT_JSON
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json
#FIREBASE_SERVICE_ACCOUNT_JSON={...}

# Server port (optional)
PORT=5000
